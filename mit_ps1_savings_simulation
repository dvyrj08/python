yearly_salary = float(input("What is your yearly salary? : "))
portion_saved = float(input("How much do you to save? : "))
cost_of_dream_home = float(input("What is the cost of your dream home? : "))

portion_down_payment = 0.25

amount_saved = 0

r = 0.05

actual_down_payment = portion_down_payment*cost_of_dream_home

months = 0


monthly_salary = yearly_salary/12
monthly_salary_savings = monthly_salary*portion_saved

while amount_saved < actual_down_payment:
    
    months += 1
    amount_saved=amount_saved+monthly_salary_savings+(amount_saved*(r/12))

print(months)    
